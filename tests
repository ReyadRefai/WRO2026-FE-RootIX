/**
 * @file test_vl53l0x_tca9548a.cpp
 * @brief Diagnostic test for 3x VL53L0X Time-of-Flight (ToF) distance sensors using TCA9548A I2C Multiplexer.
 * @team RootIX - WRO Future Engineers
 * 
 * @board ESP32
 * @connections
 *  - ESP32 SDA (GPIO 21) -> TCA9548A SDA
 *  - ESP32 SCL (GPIO 22) -> TCA9548A SCL
 *  - TCA Channel 0 -> Front ToF Sensor (0x29)
 *  - TCA Channel 1 -> Right ToF Sensor (0x29)
 *  - TCA Channel 2 -> Left ToF Sensor (0x29)
 */

#include <Wire.h>
#include <Adafruit_VL53L0X.h>

// Initialize sensor objects
Adafruit_VL53L0X tofFront = Adafruit_VL53L0X();
Adafruit_VL53L0X tofRight = Adafruit_VL53L0X();
Adafruit_VL53L0X tofLeft  = Adafruit_VL53L0X();

#define TCA_ADDRESS 0x70

// Helper function to switch TCA9548A I2C channels
void tcaSelect(uint8_t channel) {
  if (channel > 7) return;
  Wire.beginTransmission(TCA_ADDRESS);
  Wire.write(1 << channel);
  Wire.endTransmission();
}

void setup() {
  Serial.begin(115200);
  while (!Serial) delay(10);

  Serial.println("--- 3x VL53L0X ToF Sensors Diagnostic Test (via TCA9548A) ---");
  Wire.begin(21, 22); // ESP32 default I2C pins

  // 1. Initialize Front Sensor (Channel 0)
  tcaSelect(0);
  if (!tofFront.begin()) {
    Serial.println("❌ Failed to detect Front ToF sensor on Channel 0!");
  } else {
    Serial.println("✅ Front ToF sensor ready!");
  }

  // 2. Initialize Right Sensor (Channel 1)
  tcaSelect(1);
  if (!tofRight.begin()) {
    Serial.println("❌ Failed to detect Right ToF sensor on Channel 1!");
  } else {
    Serial.println("✅ Right ToF sensor ready!");
  }

  // 3. Initialize Left Sensor (Channel 2)
  tcaSelect(2);
  if (!tofLeft.begin()) {
    Serial.println("❌ Failed to detect Left ToF sensor on Channel 2!");
  } else {
    Serial.println("✅ Left ToF sensor ready!");
  }
}

void loop() {
  VL53L0X_RangingMeasurementData_t measure;

  // Read Front Sensor (Channel 0)
  tcaSelect(0);
  tofFront.rangingTest(&measure, false);
  Serial.print("Front ToF: ");
  if (measure.RangeStatus != 4) {
    Serial.print(measure.RangeMilliMeter);
    Serial.print(" mm");
  } else {
    Serial.print("Out of range");
  }

  // Read Right Sensor (Channel 1)
  tcaSelect(1);
  tofRight.rangingTest(&measure, false);
  Serial.print("  |  Right ToF: ");
  if (measure.RangeStatus != 4) {
    Serial.print(measure.RangeMilliMeter);
    Serial.print(" mm");
  } else {
    Serial.print("Out of range");
  }

  // Read Left Sensor (Channel 2)
  tcaSelect(2);
  tofLeft.rangingTest(&measure, false);
  Serial.print("  |  Left ToF: ");
  if (measure.RangeStatus != 4) {
    Serial.print(measure.RangeMilliMeter);
    Serial.print(" mm");
  } else {
    Serial.print("Out of range");
  }

  Serial.println();
  delay(200); // Sampling interval: 200ms
}

























